{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat/web", "dest": "api/chat.js" },
    { "src": "/webhook", "dest": "api/webhook.js" },
    { "src": "/widget.js", "dest": "public/widget.js" },
    { "src": "/widget.css", "dest": "public/widget.css" },
    { "src": "/style.css", "dest": "style.css" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
