{
  "version": 2,
  "builds": [
    {
      "src": "src-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/webhook", "dest": "/api/index.js" }
  ]
}
