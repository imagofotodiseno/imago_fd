# Puerto del servidor
PORT=3000

# Google Gemini API Key
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Meta / WhatsApp / Messenger Tokens
# (Obtenidos en Meta for Developers)
META_VERIFY_TOKEN=un_token_secreto_que_tu_eliges
META_ACCESS_TOKEN=tu_token_de_acceso_permanente_de_meta

# Número de teléfono de WhatsApp (Identificador)
WHATSAPP_PHONE_ID=tu_phone_number_id_aqui
