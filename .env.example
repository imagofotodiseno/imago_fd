PORT=3001
WH_WEBHOOK_VERIFY_TOKEN=change_me
DEFAULT_COUNTRY_CODE=+57
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
# ─────────────────────────────────────────────────────────────
#  IMAGO MICRO-CRM — Variables de Entorno
#  Copia este archivo como .env para desarrollo local:
#    cp .env.example .env
#  Para Netlify: configúralas en el panel, NO en este archivo.
# ─────────────────────────────────────────────────────────────

# ── Servidor local (no se usa en Netlify) ─────────────────────
PORT=3000

# ── Google Gemini ──────────────────────────────────────────────
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# ── Meta / WhatsApp Cloud API ─────────────────────────────────
# Crea tu app en: https://developers.facebook.com
# Token que tú inventas para validar el webhook de Meta:
META_VERIFY_TOKEN=imago_webhook_secreto_2024

# Token permanente del sistema (System User Token en Meta Business Suite):
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# ID del número de teléfono de WhatsApp Business:
WHATSAPP_PHONE_ID=123456789012345
